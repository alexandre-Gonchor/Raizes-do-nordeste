          sortKey: -1777235626882
          description: ""
        children:
          - url: http://localhost:8080/usuarios
            name: T01 - Cadastro de Usuário (201)
            meta:
              id: req_2aeb2dd44ec34bc88ab439dc3735b423
              created: 1777235628091
              modified: 1777235628091
              isPrivate: false
              description: |-
                **Cenário:** Cadastro de usuário válido

                **Endpoint:** POST /usuarios

                **Pré-condição:** Nenhuma

                **Entrada:** Dados do usuário e aceite LGPD

                **Esperado:** 201 Created com os dados salvos

                **Evidência:** T01 - Cadastro de Usuário
              sortKey: -1777235626881
            method: POST
            body:
              mimeType: text/plain
              text: |-
                {
                  "canalPedido": "APP",
                  "nome": "Guilherme",
                  "email": "gui@email.com",
                  "senha": "1234",
                  "role": "CLIENTE",
                  "consentimentoLgpd": true
                }
            headers:
              - name: Content-Type
                value: application/json
            settings:
              renderRequestBody: true
              encodeUrl: true
              followRedirects: global
              cookies:
                send: true
                store: true
              rebuildPath: true
