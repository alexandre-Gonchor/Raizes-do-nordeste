              id: req_05b6d923e10044c1b2d696259f721934
              created: 1777235628093
              modified: 1777235628093
              isPrivate: false
              description: |-
                **Cenário:** Autenticação de usuário para obtenção de token

                **Endpoint:** POST /auth/login

                **Pré-condição:** Usuário cadastrado no banco

                **Entrada:** Credenciais (login/senha)

                **Esperado:** 200 OK e Token JWT no corpo da resposta

                **Evidência:** T02 - Fazer Login
              sortKey: -1777235626880
            method: POST
            body:
              mimeType: text/plain
              text: |-
                {
                  "login": "gui@email.com",
                  "senha": "1234"
                }
            headers:
              - name: Content-Type
                value: application/json
            settings:
              renderRequestBody: true
              encodeUrl: true
              followRedirects: global
              cookies:
                send: true
                store: true
              rebuildPath: true
